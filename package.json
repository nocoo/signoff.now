{
	"name": "@signoff/repo",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.6",
	"workspaces": [
		"packages/*",
		"apps/*",
		"tooling/*"
	],
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@tailwindcss/typography": "^0.5.20",
		"@types/bun": "^1.3.11",
		"@vitest/coverage-v8": "^4.1.8",
		"husky": "^9.0.0",
		"lint-staged": "^16.4.0",
		"turbo": "^2.9.18",
		"typescript": "^5.9.3",
		"vitest": "^4.1.8"
	},
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo build",
		"test": "turbo test",
		"test:coverage": "turbo test:coverage",
		"lint": "bunx @biomejs/biome check --error-on-warnings .",
		"lint:fix": "bunx @biomejs/biome check --write --unsafe .",
		"format": "bunx @biomejs/biome format --write .",
		"typecheck": "tsc --noEmit && turbo typecheck",
		"prepare": "husky",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo clean",
		"db:generate": "bun run --cwd packages/local-db generate",
		"security": "bun run scripts/run-security.ts"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,jsonc,css}": [
			"bunx @biomejs/biome check --write --error-on-warnings"
		]
	},
	"dependencies": {
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1"
	},
	"overrides": {
		"@babel/core": "^7.29.6",
		"brace-expansion": "^5.0.6",
		"esbuild": "^0.28.1",
		"form-data": "^4.0.6",
		"js-yaml": "^4.2.0",
		"tar": "^7.5.16",
		"tmp": "^0.2.6",
		"undici": "^6.27.0",
		"vite": "^7.3.5"
	}
}
