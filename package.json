{
	"name": "@signoff/repo",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.6",
	"workspaces": [
		"packages/*",
		"apps/*",
		"tooling/*"
	],
	"devDependencies": {
		"@biomejs/biome": "2.4.2",
		"@tailwindcss/typography": "^0.5.19",
		"@types/bun": "^1.3.11",
		"husky": "^9.0.0",
		"lint-staged": "^16.4.0",
		"turbo": "^2.8.7",
		"typescript": "^5.9.3"
	},
	"scripts": {
		"postinstall": "bash scripts/rebuild-native.sh",
		"dev": "turbo run dev",
		"build": "turbo build",
		"test": "turbo test",
		"test:ci": "turbo test:ci",
		"lint": "bunx @biomejs/biome check .",
		"lint:fix": "bunx @biomejs/biome check --write --unsafe .",
		"format": "bunx @biomejs/biome format --write .",
		"typecheck": "tsc --noEmit && turbo typecheck",
		"prepare": "husky",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo clean",
		"db:generate:desktop": "bun run --cwd packages/local-db generate",
		"security": "bun run scripts/run-security.ts",
		"test:l2": "bun test --cwd apps/desktop src/lib/trpc/routers/__tests__/e2e-smoke.test.ts src/lib/trpc/routers/__tests__/l2-integration.test.ts"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,jsonc,css}": [
			"bunx @biomejs/biome check --write --error-on-warnings"
		]
	},
	"dependencies": {
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1"
	}
}
