{
	"name": "@signoff/pulse",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"bin": {
		"pulse": "./src/main.ts"
	},
	"exports": {
		".": {
			"types": "./src/commands/types.ts",
			"default": "./src/commands/types.ts"
		},
		"./collect": {
			"types": "./src/collect.ts",
			"default": "./src/collect.ts"
		},
		"./executor": {
			"types": "./src/executor/types.ts",
			"default": "./src/executor/types.ts"
		},
		"./identity": {
			"types": "./src/identity/types.ts",
			"default": "./src/identity/types.ts"
		},
		"./api": {
			"types": "./src/api/types.ts",
			"default": "./src/api/types.ts"
		}
	},
	"scripts": {
		"dev": "bun run src/main.ts",
		"start": "bun run src/main.ts",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false",
		"lint": "biome check --error-on-warnings .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"clean": "git clean -xdf .cache .turbo dist coverage node_modules"
	},
	"devDependencies": {
		"@signoff/typescript": "workspace:*",
		"@vitest/coverage-v8": "4.1.10",
		"bun-types": "1.3.14",
		"typescript": "7.0.2",
		"vitest": "4.1.10"
	}
}
